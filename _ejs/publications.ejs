<div class="list quarto-listing-default">
    <% for (const item of items) { %>
    <div class="quarto-post image-right" <%= metadataAttrs(item) %>>
        
        <!-- Thumbnail Section -->
        <div class="thumbnail">
            <% if (item.image) { %>
                <img alt="<%= item.title || '' %>" src="<%= item.image %>" class="thumbnail-image">
            <% } %>
        </div>

        <!-- Main Content Section -->
        <div class="body">
            <div class="no-anchor listing-pub-title listing-title">
                <%= item.title %>
            </div>
            
            <div class="listing-pub-author listing-author">
                <%= item.author %>
            </div>
            
            <% if (item.journ) { %>
                <div class="metadata-value listing-pub-journal listing-publication">
                    <i><%= item.journ %></i><!--
                 --><% if (item.issue) { %>, <b><%= item.issue %></b><% } %><!--
                 --><% if (item.page) { %>, <%= item.page %><% } %><!--
                 --><% if (item.year) { %> (<%= item.year %>)<% } %>
                </div>
            <% } %>
        </div>

        <!-- Links / Metadata Section -->
        <div class="metadata">
            <% if (item.url_source) { %>
                <div class="listing-pub-url">
                    <a href="<%- item.url_source %>" style="color: #8250E6; text-decoration: none;">
                        journal URL <i class="bi bi-box-arrow-up-right"></i>
                    </a>
                </div>
            <% } %>
  
            <% if (item.url_preprint) { %>
                <div class="listing-pub-url">
                    <a href="<%- item.url_preprint %>" style="color: #8250E6; text-decoration: none;">
                        preprint URL <i class="bi bi-box-arrow-up-right"></i>
                    </a>
                </div>
            <% } %>
        </div>

    </div>
    <% } %>
</div>